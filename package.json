{
  "name": "hotshotbot",
  "version": "1.0.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && npm run electron:compile && electron electron-dist/main.js\"",
    "electron:build": "next build && npm run electron:compile && electron-builder --mac --arm64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4",
    "@types/electron": "^1.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "node-hid": "^3.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.hotshotbot",
    "productName": "HotShotBot",
    "asar": false,
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "files": [
      "electron-dist/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/node-hid",
        "to": "node_modules/node-hid"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "allowScripts": {
    "node-hid@3.3.0": true
  }
}
